#!/usr/bin/env bash
#
# Copyright (c) Corey Goldberg (https://github.com/cgoldberg)
#
# NAS to NAS backup script:
#  - mounts remote NAS filesystems with CIFS/SMB if needed
#  - syncs files from source NAS to destination NAS
#  - saves previous 14 days of deleted/overwritten files on destination NAS
#  - unmounts bytez NAS
#
# requires:
#  - rsync
#  - sync-nas script

set -o pipefail

trap cleanup SIGINT SIGTERM


EXPECTED_HOSTS=("minime" "raspberrypi")

# 2-bay QNAP
SOURCE_NAS_HOST="bitz"
SOURCE_NAS_MNT="/mnt/${SOURCE_NAS_HOST}"

# 1-bay QNAP
DESTINATION_NAS_HOST="bytez"
DESTINATION_NAS_MNT="/mnt/${DESTINATION_NAS_HOST}"

RSYNC_TRASH_DIR="${DESTINATION_NAS_MNT}/.rsync-trash"
RSYNC_TRASH_DAYS=14

SEP="----------------------------------------------------------------"
BOLD="\e[1m"
GREEN="\e[32m"
RED="\e[31m"
RESET="\e[0m"
CHECK="\u2713"
CROSS="\u2717"


die() {
    printf "${BOLD}${RED}%b${RESET} ${BOLD}%s${RESET}\n" "${CROSS}" "$*" 1>&2
    exit 1
}

ok() {
    printf "${BOLD}${GREEN}%b${RESET} ${BOLD}%s${RESET}\n" "${CHECK}" "$*" 1>&2
}

cleanup() {
    echo
    sudo umount -l "${DESTINATION_NAS_MNT}"
    die "Aborted"
}

check_host() {
    local can_run="false"
    for i in {0..1}; do
        local host="${EXPECTED_HOSTS[${i}]}"
        if [ "${HOSTNAME}" == "${host}" ]; then
            can_run="true"
        fi
    done
    if [ "${can_run}" == "false" ] ; then
        die "fatal: can't run on this host: ${HOSTNAME}"
    fi
}

check_mounts() {
    for mnt in "${SOURCE_NAS_MNT}" "${DESTINATION_NAS_MNT}"; do
        if ! findmnt "${mnt}" >/dev/null; then
            die "fatal: ${mnt} not mounted"
        fi
    done
}

check_configuration() {
    if ! type rsync >/dev/null 2>&1; then
        die "fatal: rsync not found"
    fi
    if ! type sync-nas >/dev/null 2>&1; then
        die "fatal: sync-nas not found"
    fi
    local min_gb=100
    local min_bytes=$((min_gb * 1024 * 1024 * 1024))
    local avail
    avail=$(df --output=avail -B1 "${DESTINATION_NAS_MNT}" | tail -1)
    if ! [[ "${avail}" =~ ^[0-9]+$ ]]; then
        die "fatal: could not determine free space on destination"
    fi
    if [ "${avail}" -lt "${min_bytes}" ]; then
        die "fatal: less than ${min_gb} GB free on destination"
    fi
}

diskspace() {
    df --human-readable --sync --type=cifs | sed '1{p;s/./-/g;}'
}

timer() {
    local start_time=${SECONDS}
    "$@"
    local end_time=${SECONDS}
    local duration=$((end_time - start_time))
    local hours=$((duration / 3600))
    local minutes=$(((duration % 3600) / 60))
    local seconds=$((duration % 60))
    printf -v elapsed_time "%02d:%02d:%02d" "${hours}" "${minutes}" "${seconds}"
}

do_backup() {
    echo "syncing ${SOURCE_NAS_MNT} to ${DESTINATION_NAS_MNT}..."
    echo
    local rsync_trash="${RSYNC_TRASH_DIR}/$(date +"%Y-%m-%d_%H-%M-%S")"
    rsync \
        --backup \
        --delete-during \
        --fsync \
        --human-readable \
        --links \
        --no-whole-file \
        --numeric-ids \
        --progress \
        --recursive \
        --safe-links \
        --stats \
        --times \
        --verbose \
        --verbose \
        --backup-dir="${rsync_trash}" \
        --exclude="$(basename "${RSYNC_TRASH_DIR}")/" \
        --info=progress2 \
        --max-delete=500 \
        "${SOURCE_NAS_MNT}/" \
        "${DESTINATION_NAS_MNT}/" \
        | grep -v "file_list pointer array" \
        || die "rsync failed"
}

prune_trash() {
    find "${RSYNC_TRASH_DIR}" \
        -mindepth 1 \
        -maxdepth 1 \
        -type d \
        -mtime "+${RSYNC_TRASH_DAYS}" \
        -exec rm -rf {} \;
}

check_host
check_configuration
echo
mount-bitz >/dev/null 2>&1
mount-bytez >/dev/null 2>&1
sync-nas >/dev/null 2>&1
echo
echo "starting backup job..."
echo
echo "${SEP}"
echo
mkdir -p "${RSYNC_TRASH_DIR}"
prune_trash
sync
timer do_backup
echo "${SEP}"
sync-nas >/dev/null 2>&1
echo
echo "elapsed time: ${elapsed_time}"
echo
prune_trash
diskspace
echo
sudo umount -l "${DESTINATION_NAS_MNT}"
ok "backup complete"
