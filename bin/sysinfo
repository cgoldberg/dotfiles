# License: MIT
#
# sysinfo - display Linux system information


if [[ "${OSTYPE}" != "linux"* ]]; then
    echo "This only works on Linux"
    exit 1
fi

GRAY="\033[1;37m"
PURPLE="\033[1;35m"
GREEN="\033[1;32m"
RESET="\033[0m"

print_line () {
    local label="$1"
    local value="$2"
    printf "${GRAY}%10s${PURPLE} = ${GREEN}%s${RESET}\n" "${label}" "${value}"
}

get_cpu_info () {
    local cpu_count cpu_model
    cpu_count=$(nproc)
    cpu_model=$(awk -F': ' '/model name/ {print $2; exit}' /proc/cpuinfo)
    echo "${cpu_count} x ${cpu_model}"
}

get_disk_used () {
    df --block-size=1 --local --portability / | awk 'NR==2 {
        used=$3; total=$2;
        used_gib = used / 1024 / 1024 / 1024
        total_gib = total / 1024 / 1024 / 1024
        printf "%.2fG / %.2fG Used (%.1f%%)",
               used_gib, total_gib, (used/total)*100
    }'
}

get_mem_used () {
    awk '
        /MemTotal/     { total=$2 }
        /MemAvailable/ { avail=$2 }
        END {
            used = total - avail
            printf "%.2fG / %.2fG Used (%.1f%%)",
                   used/1024/1024,
                   total/1024/1024,
                   (used/total)*100
        }' /proc/meminfo
}

get_ip_addresses () {
    local ipv4 ipv6
    ipv4=$(ip -4 route get 1.1.1.1 2>/dev/null)
    ipv4=${ipv4#*src }
    ipv4=${ipv4%% *}
    ipv6=$(ip -6 route get 2606:4700:4700::1111 2>/dev/null)
    ipv6=${ipv6#*src }
    ipv6=${ipv6%% *}
    if [ -n "${ipv4}" ]; then
        print_line "IPv4" "${ipv4}"
    fi
    if [ -n "${ipv6}" ]; then
        print_line "IPv6" "${ipv6}"
    fi
}

get_uptime () {
    uptime -p | cut -d ' ' -f 2-
}

get_process_count () {
    ps -e --no-headers | wc -l
}

get_os_info () {
    local host distro kernel arch
    host=$(hostnamectl --static)
    distro=$(lsb_release -s -d)
    kernel=$(uname -r)
    arch=$(uname -m)
    print_line "Host" "${host}"
    print_line "Distro" "${distro}"
    print_line "Kernel" "${kernel}"
    print_line "Platform" "${arch}"
}


echo
get_os_info
print_line "Uptime" "$(get_uptime)"
print_line "CPU" "$(get_cpu_info)"
get_ip_addresses
print_line "Memory" "$(get_mem_used)"
print_line "Disk" "$(get_disk_used)"
print_line "Processes" "$(get_process_count)"
echo
