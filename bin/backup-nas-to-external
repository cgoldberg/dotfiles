#!/usr/bin/env bash
#
# Copyright (c) Corey Goldberg (https://github.com/cgoldberg)
#
# NAS to external backup script:
#  - mount remote NAS filesystem with CIFS/SMB if needed
#  - sync files from NAS to external USB drive
#
# requires:
#  - rsync

trap cleanup SIGINT SIGTERM


# 2-bay QNAP
NAS_HOST="bitz"
NAS_MNT="/mnt/${NAS_HOST}"

# External SSD
USB_NAME="T7Shield"
USB_MNT="/media/${USER}/${USB_NAME}"

ALLOWED_HOSTS=("minime" "raspberrypi")
MIN_USB_GB=50

SEP="----------------------------------------------------------------"
BOLD="\e[1m"
GREEN="\e[32m"
RED="\e[31m"
RESET="\e[0m"
CHECK="\u2713"
CROSS="\u2717"


die() {
    printf "${BOLD}${RED}%b${RESET} ${BOLD}%s${RESET}\n" "${CROSS}" "$*" 1>&2
    exit 1
}

ok() {
    printf "${BOLD}${GREEN}%b${RESET} ${BOLD}%s${RESET}\n" "${CHECK}" "$*" 1>&2
}

cleanup() {
    echo
    eject_usb
    die "Aborted"
}

check_host() {
    local can_run="false"
    for i in {0..1}; do
        local host="${ALLOWED_HOSTS[${i}]}"
        if [ "${HOSTNAME}" == "${host}" ]; then
            can_run="true"
        fi
    done
    if [ "${can_run}" == "false" ] ; then
        die "fatal: can not run on this host: ${HOSTNAME}"
    fi
}

check_mounts() {
    for mnt in "${NAS_MNT}" "${USB_MNT}"; do
        if ! findmnt "${mnt}" >/dev/null; then
            die "fatal: ${mnt} not mounted"
        fi
    done
}

check_configuration() {
    if ! type rsync >/dev/null 2>&1; then
        die "fatal: rsync not found"
    fi
    local min_bytes=$((${MIN_USB_GB} * 1024 * 1024 * 1024))
    local avail
    avail=$(df --output=avail -B1 "${USB_MNT}" | tail -1)
    if ! [[ "${avail}" =~ ^[0-9]+$ ]]; then
        die "fatal: could not determine free space on destination"
    fi
    if [ "${avail}" -lt "${min_bytes}" ]; then
        die "fatal: less than ${min_gb} GB free on destination"
    fi
}

diskspace() {
    df --human-readable --sync --type=exfat | sed '1{p;s/./-/g;}'
}

eject_usb() {
    sync
    local partition=$(findmnt -rno SOURCE "${USB_MNT}")
    local device_name=$(lsblk -rno PKNAME "${partition}")
    local disk="/dev/${device_name}"
    sudo udisksctl unmount -b "${partition}" >/dev/null
    sudo udisksctl power-off -b "${disk}" >/dev/null
}

timer() {
    local start_time=${SECONDS}
    "$@"
    local end_time=${SECONDS}
    local duration=$((end_time - start_time))
    local hours=$((duration / 3600))
    local minutes=$(((duration % 3600) / 60))
    local seconds=$((duration % 60))
    printf -v elapsed_time "%02d:%02d:%02d" "${hours}" "${minutes}" "${seconds}"
}

do_backup() {
    echo "syncing ${NAS_MNT} to ${USB_MNT}..."
    echo
    rsync \
        --delete-during \
        --fsync \
        --human-readable \
        --links \
        --no-whole-file \
        --numeric-ids \
        --progress \
        --recursive \
        --safe-links \
        --stats \
        --times \
        --verbose \
        --verbose \
        --max-delete=500 \
        --info=progress2 \
        --exclude='d0/' \
        --exclude='d1/' \
        "${NAS_MNT}/" \
        "${USB_MNT}/" \
        | grep -v "file_list pointer array"
}

check_host
check_configuration
echo
mount-bitz
check_mounts
echo
echo "starting backup job..."
echo
echo "${SEP}"
echo
timer do_backup
echo
echo "${SEP}"
echo
sync "${USB_MNT}"
echo "elapsed time: ${elapsed_time}"
echo
diskspace
echo
eject_usb
ok "ejected external drive"
echo
ok "backup complete"
